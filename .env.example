# Environment Variables for Smart Farming Dashboard
# Copy this to .env.local for local development
# For Vercel deployment, set these in your Vercel project settings

# SMTP settings for email delivery (Gmail)
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USERNAME=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM="SmartFarm <your-gmail@gmail.com>"

# Debug mode (set to false for production)
NEXT_PUBLIC_DEBUG_OTP=false