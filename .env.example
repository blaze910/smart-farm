# Map and geocoding
NEXT_PUBLIC_LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_LEAFLET_ATTRIBUTION=&copy; OpenStreetMap contributors
NEXT_PUBLIC_GEOCODE_API_URL=https://nominatim.openstreetmap.org/search

# Pest Prophet API
NEXT_PUBLIC_PEST_PROPHET_API_URL=https://api.pestprophet.example.com/v1
NEXT_PUBLIC_PEST_PROPHET_API_KEY=your_pest_prophet_api_key

# Weather and climate data
NEXT_PUBLIC_WEATHER_API_URL=https://api.weather.example.com/v1
NEXT_PUBLIC_WEATHER_API_KEY=your_weather_api_key

# Market price data
NEXT_PUBLIC_MARKET_PRICES_API_URL=https://api.marketprices.example.com/v1
NEXT_PUBLIC_MARKET_PRICES_API_KEY=your_market_prices_api_key

# Optional soil / satellite tile layer
NEXT_PUBLIC_SOIL_LAYER_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
